# ============================================================================
# liveTrade configuration — copy this file to ".env" and fill in the values.
# (Run on the Windows PC where the MT5 / Exness terminal is logged in.)
# ============================================================================

# ---- MetaTrader 5 / Exness ----
# Leave LOGIN/PASSWORD/SERVER blank to attach to the already-logged-in terminal.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=                 # e.g. Exness-MT5Real  or  Exness-MT5Trial
MT5_PATH=                   # optional: full path to terminal64.exe (e.g. C:\Program Files\MetaTrader 5\terminal64.exe)
MT5_SYMBOL_SUFFIX=          # Exness symbol suffix if any (e.g. "m"  ->  EURUSDm). Leave blank to auto-resolve.

# ---- What to trade ----
# Comma-separated. Default = the validated Strategy-95 basket.
SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,NZDUSD,USDCAD

# ---- Position sizing (margin-based, fixed stake) ----
ACCOUNT_CCY=INR
MARGIN_PER_TRADE_INR=1000   # margin committed per trade
LEVERAGE=2000               # account leverage (Exness 1:2000)
MAX_LOT=50                  # hard cap on lot size per trade (safety)

# ---- Risk guards ----
DRY_RUN=true                # true = log signals only, DO NOT place real orders. Set false to go live.
ONE_TRADE_PER_PAIR=true
MAX_CONCURRENT_TRADES=5
MAX_DAILY_LOSS_INR=10000    # pause new trades once realised loss for the day exceeds this (0 = disabled)

# ---- Engine loop ----
POLL_SECONDS=15             # how often the scheduler wakes up
CANDLE_CLOSE_LAG_SEC=8      # wait this long after a candle closes before scanning (broker settle)

# ---- Email alerts (Gmail: use an App Password, not your login password) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ---- Strategy 95 params (defaults match the validated backtest; override only if you know why) ----
PARTIAL_R=0.5
FINAL_R=1.5
BIAS_TTL_HOURS=16
MIN_DISPLACEMENT_PCT=0.10
FOREX_SL_BUFFER_PIPS=15
